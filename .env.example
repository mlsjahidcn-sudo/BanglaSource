# BanglaSource — environment variable template
#
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# All variables starting with NEXT_PUBLIC_ are exposed to the browser;
# everything else is server-only.

# ─── Supabase (official cloud) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_ANON_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ─── Site URL (used in transactional emails + share links) ───────
NEXT_PUBLIC_SITE_URL=https://banglasource.com

# ─── Apify (1688 price refresh + product discovery) ─────────────
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── DeepSeek V4 family (only model family we use) ──────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ─── GPT Image 2 (via apinebula.com proxy) ──────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://apinebula.com/v1
OPENAI_IMAGE_MODEL=gpt-image-2-vip

# ─── Cron (auth for /api/cron/* routes) ─────────────────────────
CRON_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Transactional email (Phase 18) ────────────────────────────
# Provider: Resend (https://resend.com) — free tier 3k/mo, 100/day.
# Get your API key at https://resend.com/api-keys.
# When RESEND_API_KEY is unset, /lib/email.ts logs the payload
# to stdout instead of calling the API. Safe in dev, also fine
# in prod for a quiet first day.
#
# EMAIL_FROM must use a verified domain (https://resend.com/domains).
# EMAIL_REPLY_TO is optional — defaults to EMAIL_FROM.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="BanglaSource <orders@banglasource.com>"
EMAIL_REPLY_TO="support@banglasource.com"
